DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated https origins for admin/forms when DEBUG=False (optional —
# auto-derived from ALLOWED_HOSTS if unset).
# DJANGO_CSRF_TRUSTED_ORIGINS=https://pitwall.example.com

POSTGRES_DB=f1
POSTGRES_USER=f1
POSTGRES_PASSWORD=f1
# Leave blank for local SQLite. docker-compose injects POSTGRES_HOST=postgres.
# POSTGRES_HOST=
POSTGRES_PORT=5432

# Leave blank for local locmem cache. docker-compose injects Redis/Celery URLs.
# REDIS_URL=

# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

JOLPICA_USER_AGENT=f1app/1.0
JOLPICA_BASE=https://api.jolpi.ca/ergast/f1

# FastF1 disk cache (v2 telemetry). docker-compose injects /cache/fastf1;
# leave unset locally to default to ./.fastf1cache.
# FASTF1_CACHE_DIR=/cache/fastf1

# Logs. Rotating files (web.log + bot.log) land here when DJANGO_DEBUG=False.
# docker-compose injects /var/log/pitwall; leave unset locally to default to
# ./logs (which is gitignored).
# LOG_DIR=/var/log/pitwall

# Telegram bot. Rotate via @BotFather (/revoke) before deploying.
TELEGRAM_BOT_TOKEN=
# Used as the path segment for the webhook URL; pick a long random hex string.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated numeric Telegram user IDs allowed to run /sync etc.
TELEGRAM_ADMIN_IDS=
# Set to "false" to stop runserver from auto-starting the bot poller (default: on).
RUN_BOT_WITH_SERVER=true
